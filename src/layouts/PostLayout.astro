---
import BaseLayout from './BaseLayout.astro';
import TagList from '../components/TagList.astro';
import FollowUpBanner from '../components/FollowUpBanner.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  minutesRead?: string;
  followsUp?: string;
  collection: 'essays' | 'links';
  externalUrl?: string;
}

const { title, description, pubDate, tags = [], minutesRead, followsUp, collection, externalUrl } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

let followUpTarget = null;
if (followsUp) {
  const essays = await getCollection('essays');
  followUpTarget = essays.find(e => e.id === followsUp);
}
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <header class="post-header">
      {followUpTarget && (
        <FollowUpBanner
          title={followUpTarget.data.title}
          href={`/essays/${followUpTarget.id}`}
        />
      )}
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {minutesRead && <span>&middot; {minutesRead}</span>}
        {collection === 'links' && externalUrl && (
          <span>&middot; <a href={externalUrl} target="_blank" rel="noopener noreferrer">Source &rarr;</a></span>
        )}
      </div>
      {tags.length > 0 && <TagList tags={tags} />}
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .post-meta {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
</style>
