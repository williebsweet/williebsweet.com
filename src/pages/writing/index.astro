---
import PageLayout from '../../layouts/PageLayout.astro';
import PostList from '../../components/PostList.astro';
import { getAllPosts } from '../../utils/posts';

const posts = await getAllPosts();
---

<PageLayout title="Primitive Thinking — Will Sweet" description="Essays and links on AI, data, and strategy.">
  <section class="writing-hero" aria-labelledby="writing-title">
    <p class="page-kicker">Writing</p>
    <h1 id="writing-title" class="page-title">Primitive Thinking</h1>
    <p class="page-tagline">Simple, not simplistic</p>
  </section>

  <section class="writing-feed" aria-label="Posts">
    <div class="feed-header">
      <h2>Latest</h2>
      <span>{posts.length} {posts.length === 1 ? 'entry' : 'entries'}</span>
    </div>
    {posts.length > 0 ? (
      <div class="post-list-shell">
        <PostList posts={posts} showDescription />
      </div>
    ) : (
      <p class="empty">Nothing here yet. Check back soon.</p>
    )}
  </section>
</PageLayout>

<style>
  .writing-hero {
    position: relative;
    padding: 2rem 0 2.25rem;
    margin-bottom: 2rem;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .writing-hero::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 0;
    width: 5rem;
    height: 2px;
    background: var(--color-primary);
  }

  .page-kicker,
  .feed-header span {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-kicker {
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .page-title {
    font-size: clamp(2.25rem, 6vw, 4rem);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .page-tagline {
    color: var(--color-text-secondary);
    font-family: var(--font-heading);
    font-size: clamp(1.125rem, 3vw, 1.5rem);
    line-height: 1.4;
    max-width: 28rem;
  }

  .writing-feed {
    margin-bottom: 2rem;
  }

  .feed-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.875rem;
  }

  .feed-header h2 {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .feed-header span {
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .post-list-shell {
    border-top: 1px solid var(--color-border);
  }

  .post-list-shell :global(.post-item) {
    padding: 1.125rem 0;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .post-list-shell :global(.post-item:first-child) {
    padding-top: 1.125rem;
  }

  .post-list-shell :global(.post-item:hover) {
    border-bottom-color: color-mix(in srgb, var(--color-primary) 40%, var(--color-border));
    transform: translateX(0.25rem);
  }

  .post-list-shell :global(.post-title) {
    font-size: 1.25rem;
  }

  .post-list-shell :global(.post-desc) {
    max-width: 34rem;
  }

  .empty {
    color: var(--color-text-muted);
    font-style: italic;
  }

  @media (max-width: 560px) {
    .writing-hero {
      padding: 1.5rem 0 1.75rem;
      margin-bottom: 1.5rem;
    }

    .feed-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.25rem;
    }

    .post-list-shell :global(.post-item) {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.5rem;
      transform: none;
    }

    .post-list-shell :global(.post-item:hover) {
      transform: none;
    }

    .post-list-shell :global(.post-date) {
      min-width: 0;
    }

    .post-list-shell :global(.post-title) {
      line-height: 1.25;
    }
  }
</style>
