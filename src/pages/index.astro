---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import PostList from '../components/PostList.astro';
import { getRecentPosts } from '../utils/posts';

const recentPosts = await getRecentPosts(5);

const projects = [
  {
    name: 'context-graph',
    description: 'Knowledge graph engine for agentic AI with temporal reasoning and conflict detection.',
    tags: ['Python', 'LLM', 'Graph'],
    url: 'https://github.com/williebsweet/context-graph',
  },
  {
    name: 'SEAM',
    description: 'Transformer foundation models trained on raw product event sequences for churn prediction.',
    tags: ['Python', 'ML', 'Transformers'],
    url: 'https://github.com/williebsweet/SEAM',
  },
  {
    name: 'db_magic',
    description: 'Jupyter magic commands for Databricks SQL exploration.',
    tags: ['Python', 'SQL', 'Jupyter'],
    url: 'https://github.com/williebsweet/db_magic',
  },
  {
    name: 'measure-anything',
    description: 'Agent skills library that operationalizes Hubbard\'s measurement framework into composable skills for Claude Code.',
    tags: ['Python', 'Agent Skills', 'Decision Science'],
    url: 'https://github.com/williebsweet/measure-anything',
  },
];
---

<BaseLayout title="Will Sweet" description="I build at the intersection of applied AI/ML and business strategy.">
  <div class="landing">
    <!-- Hero -->
    <section class="hero">
      <h1 class="hero-heading">I'm <span class="accent">Will</span>.</h1>
      <p class="hero-subtext">
        I build at the intersection of applied AI, data infrastructure, and business strategy.
      </p>
      <SocialLinks />
    </section>

    <!-- Recent Writing -->
    {recentPosts.length > 0 && (
      <section class="section">
        <h2 class="section-label">Primitive Thinking</h2>
        <PostList posts={recentPosts} />
        <a href="/writing" class="view-all">View all &rarr;</a>
      </section>
    )}

    <!-- Projects -->
    <section class="section">
      <h2 class="section-label">Projects</h2>
      <div class="project-grid">
        {projects.map(project => (
          <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-card">
            <h3 class="project-name">{project.name}</h3>
            <p class="project-desc">{project.description}</p>
            <div class="project-tags">
              {project.tags.map(tag => (
                <span class="project-tag">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .landing {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1.5rem 2rem;
  }

  /* Hero */
  .hero {
    margin-bottom: 4rem;
  }

  .hero-heading {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .accent {
    color: var(--color-primary);
  }

  .hero-subtext {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1rem;
    max-width: 560px;
  }

  /* Sections */
  .section {
    margin-bottom: 4rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  .view-all {
    display: inline-block;
    margin-top: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-primary);
  }

  /* Projects */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .project-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    text-decoration: none;
    transition: border-color 0.2s ease;
  }

  .project-card:hover {
    border-color: var(--color-primary);
  }

  .project-name {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .project-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .project-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .project-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.125rem 0.5rem;
  }

  @media (max-width: 768px) {
    .landing {
      padding: 2rem 1.25rem 1rem;
    }

    .hero {
      margin-bottom: 3rem;
    }

    .section {
      margin-bottom: 3rem;
    }

    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
