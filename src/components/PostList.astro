---
interface PostItem {
  id: string;
  collection: string;
  data: {
    title: string;
    pubDate: Date;
    description?: string;
    pinned?: boolean;
  };
}

interface Props {
  posts: PostItem[];
  showDescription?: boolean;
}

const { posts, showDescription = false } = Astro.props;
---

<ul class="post-list">
  {posts.map(post => {
    const href = `/${post.collection}/${post.id}`;
    const date = post.data.pubDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });
    return (
      <li class="post-item">
        <span class="post-date">{date}</span>
        <div>
          <a href={href} class="post-title">{post.data.pinned && <svg class="pin-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 17v5"/><path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z"/></svg>}{post.data.title}</a>
          {showDescription && post.data.description && (
            <p class="post-desc">{post.data.description}</p>
          )}
        </div>
      </li>
    );
  })}
</ul>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    padding-top: 0;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    min-width: 90px;
  }

  .pin-icon {
    margin-right: 0.375rem;
    vertical-align: -0.1em;
    color: var(--color-text-muted);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .post-title:hover {
    color: var(--color-primary);
  }

  .post-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
    line-height: 1.5;
  }
</style>
